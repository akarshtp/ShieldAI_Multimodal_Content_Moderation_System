# =============================================================================
# ShieldAI — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-wheel-metadata/
*.manifest
*.spec

# ── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── PyTorch & ML Models ──────────────────────────────────────────────────────
*.pt
*.pth
*.bin
*.onnx
*.safetensors
models/
model_cache/
.cache/

# ── HuggingFace ──────────────────────────────────────────────────────────────
*.lock
hub/

# ── Testing & Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ── Type Checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Data & Databases ─────────────────────────────────────────────────────────
data/
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Jupyter Notebooks (checkpoints) ──────────────────────────────────────────
.ipynb_checkpoints/

# ── Distribution / Packaging ─────────────────────────────────────────────────
*.tar.gz
*.zip
